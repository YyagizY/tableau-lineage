# Tableau Cloud PAT
# Create at: your-pod.online.tableau.com → Account Settings → Personal Access Tokens
# Required scopes: tableau:metadata:read, tableau:workbooks:read, tableau:datasources:read
TABLEAU_PAT_NAME=your-pat-name
TABLEAU_PAT_SECRET=your-pat-secret

# Databricks
# Create at: your-workspace.azuredatabricks.net → Settings → User Settings → Access Tokens
# Required scope: Unity Catalog read / metastore access
DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
DATABRICKS_PAT=your-databricks-pat
