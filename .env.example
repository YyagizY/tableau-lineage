# Tableau Cloud PAT
# Create at: your-pod.online.tableau.com → Account Settings → Personal Access Tokens
# Required scopes: tableau:metadata:read, tableau:workbooks:read, tableau:datasources:read
# The PAT's user must also have Download Workbook permission on the target workbook.
TABLEAU_PAT_NAME=your-pat-name
TABLEAU_PAT_SECRET=your-pat-secret

# Databricks
# Create at: your-workspace.cloud.databricks.com → Settings → User → Developer → Access Tokens
# Required: SQL warehouse "Can Use" permission + read access on target catalogs.
DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_PAT_SECRET=your-databricks-pat

# Optional: explicit warehouse ID. If omitted, the pipeline auto-picks a RUNNING warehouse.
# DATABRICKS_WAREHOUSE_ID=
